mixin box-search()
  .row.mb-2
    .col-sm-6
      .data-table-length
        label.form-label.d-flex.gap-2.align-items-center
          | Display 
          select.form-select.form-select-sm
            option(value=5 selected) 5
            option(value=10) 10
            option(value=15) 15
          | products
    .col-sm-6
      form.text-end(id="form-search")
        .input-group 
          input(
            type="text"
            placeholder="Enter..."
            name="keyword"
            class="form-control"
            value=keyword
          )
          .input-group-append 
            button(
              class="btn btn-success"
              type="submit"
            ) Tìm

